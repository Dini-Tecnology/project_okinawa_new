# Supabase Edge Functions secrets
#
# Local:
#   cp platform/supabase/.env.example platform/supabase/.env
#   supabase functions serve --env-file platform/supabase/.env
#
# Remote:
#   cd platform/supabase
#   supabase secrets set --env-file .env --project-ref eplivpvqemowmbivhfpx

SUPABASE_URL=https://eplivpvqemowmbivhfpx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Resend > API Keys
RESEND_API_KEY=

# The sender domain must be verified in Resend for reliable delivery.
RESEND_FROM_EMAIL="NOOWE <notification@noowebr.com>"

# Public logo URLs used in transactional emails (hosted on noowebr.com/public/email)
EMAIL_LOGO_URL_RESTAURANT=https://noowebr.com/email/logo-restaurant.png
EMAIL_LOGO_URL_CLIENT=https://noowebr.com/email/logo-client.png
# Optional override for all apps:
# EMAIL_LOGO_URL=

# Optional comma-separated overrides.
ALLOWED_ORIGINS=https://noowebr.com,https://www.noowebr.com
AUTH_REDIRECT_ALLOW_LIST=okinawa-restaurant://auth/callback,okinawa-client://auth/callback,https://noowebr.com/auth/callback,https://www.noowebr.com/auth/callback
