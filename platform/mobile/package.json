{
  "name": "okinawa-mobile",
  "version": "1.0.0",
  "description": "Project Okinawa - Mobile Apps (React Native + Expo)",
  "private": true,
  "workspaces": [
    "apps/*",
    "shared"
  ],
  "overrides": {
    "expo": "^55.0.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "@expo/vector-icons": "15.1.1"
  },
  "scripts": {
    "postinstall": "patch-package",
    "client": "cd apps/client && npm start",
    "restaurant": "cd apps/restaurant && npm start",
    "client:ios": "cd apps/client && npm run ios",
    "client:android": "cd apps/client && npm run android",
    "restaurant:ios": "cd apps/restaurant && npm run ios",
    "restaurant:android": "cd apps/restaurant && npm run android",
    "build:client:ios": "cd apps/client && eas build --platform ios",
    "build:client:android": "cd apps/client && eas build --platform android",
    "build:restaurant:ios": "cd apps/restaurant && eas build --platform ios",
    "build:restaurant:android": "cd apps/restaurant && eas build --platform android",
    "test": "jest",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.5",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.4.5",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.0",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "babel-jest": "^29.7.0",
    "babel-preset-expo": "~55.0.0",
    "eslint": "^9.32.0",
    "eslint-config-expo": "~55.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.0",
    "hermes-compiler": "^250829098.0.2",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.16",
    "patch-package": "^8.0.0",
    "prettier": "^3.4.0",
    "react-test-renderer": "19.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@react-native-community/netinfo": "11.5.2",
    "@react-native-firebase/analytics": "^23.5.0",
    "@react-native-firebase/app": "^23.5.0",
    "@sentry/react-native": "~7.11.0",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/react-query": "^5.90.12",
    "expo-device": "~55.0.15",
    "expo-linking": "~55.0.14",
    "expo-local-authentication": "~55.0.13",
    "expo-notifications": "~55.0.21",
    "expo-modules-core": "55.0.23",
    "react-native-toast-message": "^2.3.3"
  }
}
