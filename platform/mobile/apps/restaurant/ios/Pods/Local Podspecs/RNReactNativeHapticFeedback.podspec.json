{
  "name": "RNReactNativeHapticFeedback",
  "version": "3.0.0",
  "summary": "Basic haptic feedback for iOS and android",
  "description": "react-native-haptic-feedback",
  "homepage": "https://github.com/mkuczera/react-native-haptic-feedback",
  "license": {
    "type": "MIT"
  },
  "authors": {
    "Michael Kuczera": "m.kuczera@gmail.com"
  },
  "platforms": {
    "ios": "13.0"
  },
  "source": {
    "git": "https://github.com/mkuczera/react-native-haptic-feedback.git",
    "tag": "v3.0.0"
  },
  "source_files": "ios/**/*.{h,m,mm}",
  "requires_arc": true,
  "frameworks": [
    "CoreHaptics",
    "AudioToolbox"
  ],
  "compiler_flags": "-DRCT_NEW_ARCH_ENABLED=1",
  "dependencies": {
    "React-Core": [],
    "React-RCTFabric": [],
    "ReactCodegen": [],
    "RCTRequired": [],
    "RCTTypeSafety": [],
    "ReactCommon/turbomodule/bridging": [],
    "ReactCommon/turbomodule/core": [],
    "React-NativeModulesApple": [],
    "Yoga": [],
    "React-Fabric": [],
    "React-graphics": [],
    "React-utils": [],
    "React-featureflags": [],
    "React-debug": [],
    "React-ImageManager": [],
    "React-rendererdebug": [],
    "React-jsi": [],
    "React-renderercss": [],
    "hermes-engine": [],
    "ReactNativeDependencies": [],
    "React-Core-prebuilt": []
  },
  "pod_target_xcconfig": {
    "HEADER_SEARCH_PATHS": "\"$(PODS_ROOT)/Headers/Private/Yoga\"",
    "CLANG_CXX_LANGUAGE_STANDARD": "c++20",
    "OTHER_CPLUSPLUSFLAGS": "$(inherited) -DRCT_NEW_ARCH_ENABLED=1 ",
    "OTHER_SWIFT_FLAGS": "$(inherited) -DRCT_NEW_ARCH_ENABLED"
  }
}
