# Copie para .env na raiz desta app e preencha (não commite .env com segredos reais).
# Reinicie o Metro com cache limpo após alterar: npx expo start -c
#
# Google OAuth — Google Cloud Console → APIs e Serviços → Credenciais
# Android: tipo "Android", package com.noowe.restaurant, SHA-1 do debug.keystore
# iOS: tipo "iOS"
# Web/Expo: cliente OAuth tipo "Web" ou o cliente Expo conforme a doc atual
#
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
#
# API local — emulador Android usa 10.0.2.2 para alcançar o host; iOS simulador pode usar localhost.
# Dispositivo físico: IP da máquina na LAN (ex.: http://192.168.1.10:3000)
# Se omitido, o código usa localhost (iOS) ou 10.0.2.2 (Android) na porta 3000.
#
# EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:3000
# EXPO_PUBLIC_WS_URL=ws://10.0.2.2:3000
