# =============================================================================
# Noowe Cliente — variáveis de ambiente (desenvolvimento local)
#
# Uso:
#   cp .env.example .env
#
# No Expo, variáveis expostas ao app DEVEM começar com EXPO_PUBLIC_
# Após alterar o .env, reinicie o Metro ou rode de novo: npx expo run:ios
# =============================================================================

# --- Obrigatórias (Supabase) ---
# Dashboard Supabase > Project Settings > API
# Usadas por shared/config/env.ts e shared/services/supabase.ts
EXPO_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx
# Alternativa legada (use publishable key se disponível):
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Google OAuth (opcional) ---
# Google Cloud Console > APIs & Services > Credentials
# Sem isso, o login com Google fica desabilitado (shared/utils/googleOAuthEnv.ts)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=xxxxx.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=xxxxx.apps.googleusercontent.com

# --- Sentry (opcional) ---
# shared/config/sentry.ts — deixe vazio para desabilitar em dev
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_ENV=development

# --- Desenvolvimento (nunca usar em produção) ---
# Pula autenticação real e entra no app como usuário fake
# shared/config/skip-auth.ts
EXPO_PUBLIC_SKIP_AUTH=false

# =============================================================================
# Notas
# -----------------------------------------------------------------------------
# API / WebSocket: em dev, shared/config/env.ts usa http://localhost:3000 fixo.
# Não é necessário definir API_URL ou WEBSOCKET_URL neste .env.
#
# Google Maps (ExploreScreen): react-native-maps usa PROVIDER_GOOGLE.
# A chave de API é configurada nativamente (app.json / EAS secrets), não aqui.
#
# Builds de produção (EAS): variáveis como API_BASE_URL, WS_URL, SENTRY_DSN e
# FIREBASE_* são definidas em eas.json ou via `eas secret:create`, não no .env local.
# =============================================================================
