{
  "name": "RNReactNativeHapticFeedback",
  "version": "3.0.0",
  "summary": "Basic haptic feedback for iOS and android",
  "description": "react-native-haptic-feedback",
  "homepage": "https://github.com/mkuczera/react-native-haptic-feedback",
  "license": {
    "type": "MIT"
  },
  "authors": {
    "Michael Kuczera": "m.kuczera@gmail.com"
  },
  "platforms": {
    "ios": "13.0"
  },
  "source": {
    "git": "https://github.com/mkuczera/react-native-haptic-feedback.git",
    "tag": "v3.0.0"
  },
  "source_files": "ios/**/*.{h,m,mm}",
  "requires_arc": true,
  "frameworks": [
    "CoreHaptics",
    "AudioToolbox"
  ],
  "compiler_flags": "-DFOLLY_NO_CONFIG -DFOLLY_MOBILE=1 -DFOLLY_USE_LIBCPP=1 -DFOLLY_CFG_NO_COROUTINES=1 -DFOLLY_HAVE_CLOCK_GETTIME=1 -Wno-comma -Wno-shorten-64-to-32",
  "dependencies": {
    "React-Core": [],
    "RCT-Folly": [
      "2024.01.01.00"
    ],
    "glog": [],
    "React-RCTFabric": [],
    "React-Codegen": [],
    "RCTRequired": [],
    "RCTTypeSafety": [],
    "ReactCommon/turbomodule/bridging": [],
    "ReactCommon/turbomodule/core": [],
    "React-NativeModulesApple": [],
    "Yoga": [],
    "React-Fabric": [],
    "React-graphics": [],
    "React-utils": [],
    "React-featureflags": [],
    "React-debug": [],
    "React-ImageManager": [],
    "React-rendererdebug": [],
    "DoubleConversion": [],
    "hermes-engine": []
  },
  "pod_target_xcconfig": {
    "HEADER_SEARCH_PATHS": "\"$(PODS_ROOT)/boost\" \"$(PODS_ROOT)/Headers/Private/Yoga\"",
    "CLANG_CXX_LANGUAGE_STANDARD": "c++20",
    "OTHER_CPLUSPLUSFLAGS": "$(inherited) -DFOLLY_NO_CONFIG -DFOLLY_MOBILE=1 -DFOLLY_USE_LIBCPP=1 -DFOLLY_CFG_NO_COROUTINES=1 -DFOLLY_HAVE_CLOCK_GETTIME=1 -Wno-comma -Wno-shorten-64-to-32"
  }
}
